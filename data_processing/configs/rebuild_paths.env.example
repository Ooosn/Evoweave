# Copy this file to a local .env file on the target server, edit paths, then:
#   source configs/rebuild_paths.env
#   bash run_rebuild_from_originals.sh

# Preserved original-data transfer root. This must contain the original zips,
# downloaded raw assets, and transfer/full_transfer_manifest.csv tree.
export EVOWEAVE_TRANSFER_ROOT="/path/to/evoweave_full_transfer_20260623/evorig"
export EVOWEAVE_TRANSFER_MANIFEST="${EVOWEAVE_TRANSFER_ROOT}/transfer/evoweave_full_transfer_20260623/full_transfer_manifest.csv"

# Output root for the rebuild. Use a new empty directory for a full 80k run.
export EVOWEAVE_REBUILD_ROOT="/path/to/output/evoweave_rebuild_rootless_v3_80k"

# External UniRig checkout used only for tokenizer roundtrip validation.
export EVOWEAVE_UNIRIG_ROOT="/path/to/UniRig"
export EVOWEAVE_TOKENIZER_CONFIG="${EVOWEAVE_UNIRIG_ROOT}/configs/tokenizer/tokenizer_parts_articulationxl_256.yaml"

# Executables.
export PYTHON="${CONDA_PREFIX}/bin/python"
export BLENDER="/usr/bin/blender"

# Optional explicit 7z binary for nested TexVerse archives.
# export EVOWEAVE_7Z="/usr/bin/7z"

# Main rebuild settings.
export EVOWEAVE_SEQUENCE_FRAMES=40
export EVOWEAVE_MOTION_FPS_DESCRIPTOR_VERTICES=1024
export EVOWEAVE_REBUILD_LIMIT=0
export EVOWEAVE_ROOTLESS_MIN_TARGET_JOINT_MESH_BBOX_CONSISTENCY=0.4

# Parallelism. Keep these conservative on shared machines; increase only after
# confirming Blender memory and filesystem throughput are stable.
export EVOWEAVE_TEXVERSE_PASS0_WORKERS=8
export EVOWEAVE_TEXVERSE_PASS1_WORKERS=8
export EVOWEAVE_OXL_PASS1_WORKERS=8
export EVOWEAVE_PASS1_TIMEOUT_RETRIES=1
export EVOWEAVE_PASS1_PRECHECK_WORKERS=32
export EVOWEAVE_ROOTLESS_WORKERS=32
export EVOWEAVE_AUDIT_WORKERS=32
export EVOWEAVE_BLENDER_THREADS=2

# Pass1 source limits. These are structural safety caps, not final histogram
# gates.
export EVOWEAVE_MAX_JOINTS=256
export EVOWEAVE_RAW_MIN_VERTICES=1
export EVOWEAVE_MAX_VERTICES=300000
export EVOWEAVE_MAX_FACES=600000
export EVOWEAVE_MIN_COMPONENT_CONTROLLED_RATIO=0.95
